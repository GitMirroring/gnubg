#: set.c:2724
#, c-format
msgid "Unknown player `%s' (see `help set turn').\n"
msgstr "不明なプレイヤー `%s'。(see `help set turn')\n"

#: set.c:2730
msgid "You can't set both players on roll."
msgstr "手番をプレイヤー両方には設定できません。"

#: set.c:2737
#, c-format
